# Terraform working directories
**/.terraform/*
.terraform.tfstate.lock.info

# State files (local backend used for teaching — never commit real state)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Plan output artifacts
*.tfplan
*.tfplan.*

# Variable files that may contain secrets (this project uses none, but guard anyway)
*.auto.tfvars
!example.auto.tfvars

# Generated simulation artifacts — noisy diffs, regenerated by `terraform apply`
generated/*
!generated/.gitkeep

# Lock files ARE committed intentionally (pinned provider versions):
# .terraform.lock.hcl  -> tracked on purpose, do not ignore

# Editor / OS
.DS_Store
.idea/
*.swp
